    def shap_analysis(self, X, all_bit_infos, smiles_list):
        try:
            sample_size = min(100, X.shape[0])
            sample_idx = np.random.choice(X.shape[0], sample_size, replace=False)
            sample_data = X.iloc[sample_idx]
            self.shap_explainer = shap.TreeExplainer(self.model)
            shap_values = self.shap_explainer.shap_values(sample_data)
            mean_shap = np.abs(shap_values).mean(0)
            top10_indices = np.argsort(mean_shap)[-10:][::-1]
