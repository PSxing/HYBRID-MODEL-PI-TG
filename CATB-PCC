def get_morgan_fingerprint(mol):
    bit_info = {}
    fp = AllChem.GetMorganFingerprintAsBitVect(
        mol, radius=RADIUS, nBits=N_BITS, bitInfo=bit_info
    )
    return fp, bit_info


def smiles_to_fingerprint(smiles):
    try:
        mol = Chem.MolFromSmiles(smiles)
        if mol is None:
            return None, None
        fp, bit_info = get_morgan_fingerprint(mol)
        return np.array(fp), bit_info
    except Exception as e:
        print(f"处理SMILES失败: {smiles}, 错误: {str(e)}")
        return None, None


