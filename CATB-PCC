def pcc_feature_selection(X, y, descriptor_cols, n_features=SELECTED_FEATURES):
    X_descriptors = X[descriptor_cols]


    high_missing_features = []
    for col in X_descriptors.columns:
        missing_ratio = X_descriptors[col].isna().mean()
        if missing_ratio > 0.3:  # 如果缺失值比例超过30%
            high_missing_features.append(col)
            print(f"移除高缺失值特征: {col} (缺失比例: {missing_ratio:.2%})")

    X_descriptors = X_descriptors.drop(columns=high_missing_features)

    non_constant_cols = []
    for col in X_descriptors.columns:
        if X_descriptors[col].nunique() > 1:
            non_constant_cols.append(col)
        else:
            print(f"移除常数特征: {col}")

    if len(non_constant_cols) < n_features:
        print(f"警告: 只有 {len(non_constant_cols)} 个非常数特征，但请求 {n_features} 个")
        n_features = len(non_constant_cols)

    X_descriptors = X_descriptors[non_constant_cols]

    X_filled = X_descriptors.fillna(X_descriptors.mean())

    correlations = []
    for col in X_filled.columns:
        try:
            corr, _ = pearsonr(X_filled[col], y)
            correlations.append((col, abs(corr)))
        except Exception as e:
            print(f"计算特征 {col} 的PCC时出错: {str(e)}")
            correlations.append((col, 0))

    correlations.sort(key=lambda x: x[1], reverse=True)
    selected = [f[0] for f in correlations[:n_features]]

    print(f"\n使用PCC选择的{len(selected)}个分子描述符特征:")
    for i, (feat, corr_val) in enumerate(zip(selected, correlations[:n_features])):
        print(f"{i + 1}. {feat} (|PCC| = {corr_val[1]:.4f})")

    return selected


def plot_feature_clustering(X, feature_names, filename="catb_descriptor_clustering.png"):
    X_filled = X.fillna(0)
    non_constant = [c for c in X_filled.columns if X_filled[c].nunique() > 1]
    X_filled = X_filled[non_constant]
    corr = X_filled.corr().values
    corr = np.nan_to_num(corr, nan=0.0, posinf=0.0, neginf=0.0)
    linkage = hierarchy.linkage(corr, method='average', metric='euclidean')
    plt.figure(figsize=(16, 12))
    hierarchy.dendrogram(
        linkage,
        labels=non_constant,
        orientation='left',
        leaf_font_size=10,
        color_threshold=0.7 * max(linkage[:, 2])
    )
    plt.title('CatBoost Feature Clustering (Descriptors)')
    plt.xlabel('Distance')
    plt.grid(axis='x', linestyle='--', alpha=0.6)
    plt.tight_layout()
    plt.savefig(filename, dpi=300, bbox_inches='tight')
    plt.show()
    print(f"特征聚类图已保存为: {filename}")


