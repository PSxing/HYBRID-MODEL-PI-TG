    def visualize_substructure_contributions(
        self, X_sample, smiles_list, bit_infos, num_bits=5
    ):
        try:
            if self.shap_explainer is None:
                self.shap_explainer = shap.TreeExplainer(self.model)
            shap_values = self.shap_explainer.shap_values(X_sample)
            mean_shap = np.abs(shap_values).mean(0)
            top_indices = np.argsort(mean_shap)[-num_bits:][::-1]
            top_features = [
                self.feature_names[i] for i in top_indices
                if i < len(self.feature_names)
            ]
            if not top_features:
                print("没有找到重要特征")
                return None

            print(f"\nTop {num_bits} 最重要的分子指纹位:")
            for i, feat in enumerate(top_features):
                print(
                    f"{i + 1}. {feat} (平均|SHAP| = {mean_shap[top_indices[i]]:.4f})"
                )

            for i, feat in enumerate(top_features):
                if not feat.startswith("Bit_"):
                    continue

                bit_idx = int(feat.split("_")[1])
                print(f"\n可视化指纹位 {bit_idx} 的子结构:")

                for j, (smiles, bit_info) in enumerate(zip(smiles_list, bit_infos)):
                    if bit_idx in bit_info:
                        mol = Chem.MolFromSmiles(smiles)
                        if mol is not None:
                            print(f"分子 {j + 1}: {smiles}")
                            self._draw_bit_highlight(
                                mol, bit_info, bit_idx,
                                f"catb_bit_{bit_idx}_mol_{j + 1}.png"  # 文件名改为catb前缀
                            )
                        break
                else:
                    print(f"没有找到包含指纹位 {bit_idx} 的分子")
            return top_features
        except Exception as e:
            print(f"子结构贡献图时出错: {str(e)}")
            return None

    def _draw_bit_highlight(self, mol, bit_info, bit_idx, filename):
        try:
            highlight_atoms, highlight_bonds = set(), set()
            atom_colors, bond_colors = {}, {}

            if bit_idx in bit_info:
                for atom, radius in bit_info[bit_idx]:
                    highlight_atoms.add(atom)
                    env = Chem.FindAtomEnvironmentOfRadiusN(mol, radius, atom)
                    highlight_bonds.update(env)
                    atom_colors[atom] = (1.0, 0.0, 0.0, 1.0)
                    for bond_idx in env:
                        bond_colors[bond_idx] = (1.0, 0.0, 0.0, 1.0)

            drawer = rdMolDraw2D.MolDraw2DCairo(500, 500)
            drawer.SetFontSize(6)
            drawer.DrawMolecule(
                mol,
                highlightAtoms=list(highlight_atoms),
                highlightBonds=list(highlight_bonds),
                highlightAtomColors=atom_colors,
                highlightBondColors=bond_colors
            )
            drawer.FinishDrawing()

            with open(filename, 'wb') as f:
                f.write(drawer.GetDrawingText())
            print(f"子结构图像已保存为: {filename}")

            img = Image.open(filename)
            plt.figure(figsize=(5, 5))
            plt.imshow(img)
            plt.axis('off')
            plt.title(f'Bit {bit_idx} Substructure')
            plt.show()
        except Exception as e:
            print(f"绘制子结构高亮时出错: {str(e)}")

    def visualize_molecule_substructures(
        self, smiles, bit_info, X_sample, shap_values, num_bits=3
    ):
        try:
            mol = Chem.MolFromSmiles(smiles)
            if mol is None:
                print(f"无法创建分子: {smiles}")
                return None

            mol_idx = (
                X_sample.index.get_loc(smiles)
                if hasattr(X_sample, 'index') else 0
            )
            mol_shap = shap_values[mol_idx]

            fingerprint_indices = [
                i for i, feat in enumerate(self.feature_names)
                if feat.startswith("Bit_")
            ]
            fingerprint_shap = mol_shap[fingerprint_indices]
            top_bit_indices = np.argsort(np.abs(fingerprint_shap))[-num_bits:][::-1]

            print(f"\n分子 {smiles} 的最重要指纹位:")
            highlight_atoms, highlight_bonds = set(), set()
            atom_colors, bond_colors = {}, {}

            for i, idx in enumerate(top_bit_indices):
                bit_idx = int(
                    self.feature_names[fingerprint_indices[idx]].split("_")[1]
                )
                shap_val = fingerprint_shap[idx]
                print(f"{i + 1}. Bit {bit_idx}: SHAP = {shap_val:.4f}")

                if bit_idx in bit_info:
                    for atom, radius in bit_info[bit_idx]:
                        highlight_atoms.add(atom)
                        color = (1.0, 0.0, 0.0, 1.0) if shap_val >= 0 else (0.0, 0.0, 1.0, 1.0)
                        atom_colors[atom] = color

                        env = Chem.FindAtomEnvironmentOfRadiusN(mol, radius, atom)
                        highlight_bonds.update(env)
                        for bond_idx in env:
                            bond_colors[bond_idx] = color

            drawer = rdMolDraw2D.MolDraw2DCairo(500, 500)
            drawer.SetFontSize(6)
            drawer.DrawMolecule(
                mol,
                highlightAtoms=list(highlight_atoms),
                highlightBonds=list(highlight_bonds),
                highlightAtomColors=atom_colors,
                highlightBondColors=bond_colors
            )
            drawer.FinishDrawing()

            filename = f"catb_molecule_{smiles[:10]}_substructures.png"  # 文件名改为catb前缀
            with open(filename, 'wb') as f:
                f.write(drawer.GetDrawingText())
            print(f"分子子结构图像已保存为: {filename}")

            img = Image.open(filename)
            plt.figure(figsize=(5, 5))
            plt.imshow(img)
            plt.axis('off')
            plt.title(f'Top {num_bits} Substructure Contributions')
            plt.show()
            return filename
        except Exception as e:
            print(f"单分子子结构可视化时出错: {str(e)}")
            return None

