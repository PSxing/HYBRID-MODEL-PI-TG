def train_model(X_train, y_train, X_val, y_val):
    search_spaces = {
        'iterations': Integer(100, 500),
        'depth': Integer(3, 10),
        'learning_rate': Real(0.01, 0.3, prior='log-uniform'),
        'l2_leaf_reg': Real(1, 10, prior='uniform'),
        'random_strength': Real(1, 10, prior='uniform'),
        'border_count': Integer(32, 255)
    }

    opt = BayesSearchCV(
        estimator=CatBoostRegressor(  # 修改为CatBoost
            random_state=SEED,
            verbose=False,
            thread_count=1
        ),
        search_spaces=search_spaces,
        n_iter=50,
        cv=5,
        scoring='neg_mean_absolute_error',
        n_jobs=1,
        verbose=100
    )

    with parallel_backend('threading', n_jobs=1):
        opt.fit(X_train, y_train)

    best_params = opt.best_params_
    best_model = opt.best_estimator_

    y_val_pred = best_model.predict(X_val)
    val_r2 = r2_score(y_val, y_val_pred)
    val_mae = mean_absolute_error(y_val, y_val_pred)
    val_rmse = np.sqrt(mean_squared_error(y_val, y_val_pred))

    return best_model, best_params, val_r2, val_mae, val_rmse


class CatBModelVisualizer: 
    def __init__(self, model, feature_names):
        self.model = model
        self.feature_names = feature_names
        self.shap_explainer = None
        self.cmap = LinearSegmentedColormap.from_list(
            "shap_red_blue", ["#0000FF", "#FF0000"], N=100
        )

    def export_all_predictions(
        self, X_train, y_train, X_val, y_val,
        train_smiles, val_smiles,
        X_test, test_smiles, test_tg,
        filename="catb_all_predictions.xlsx"  
    ):
        try:
            with pd.ExcelWriter(filename, engine='xlsxwriter') as writer:
                # 训练集
                train_pred = self.model.predict(X_train)
                train_df = pd.DataFrame({
                    'SMILES': train_smiles,
                    'True_Tg': y_train.values,
                    'Predicted_Tg': train_pred
                })
                train_df['Absolute_Error'] = np.abs(
                    train_df['True_Tg'] - train_df['Predicted_Tg']
                )
                train_df['Relative_Error(%)'] = (
                    train_df['Absolute_Error'] / train_df['True_Tg']
                ).replace([np.inf, -np.inf], np.nan) * 100
                train_df.to_excel(writer, sheet_name='Training', index=False)

                # 验证集
                val_pred = self.model.predict(X_val)
                val_df = pd.DataFrame({
                    'SMILES': val_smiles,
                    'True_Tg': y_val.values,
                    'Predicted_Tg': val_pred
                })
                val_df['Absolute_Error'] = np.abs(
                    val_df['True_Tg'] - val_df['Predicted_Tg']
                )
                val_df['Relative_Error(%)'] = (
                    val_df['Absolute_Error'] / val_df['True_Tg']
                ).replace([np.inf, -np.inf], np.nan) * 100
                val_df.to_excel(writer, sheet_name='Validation', index=False)

                # 测试集
                test_pred = (
                    self.model.predict(X_test) if not X_test.empty else []
                )
                test_df = pd.DataFrame({
                    'SMILES': [test_smiles] * len(test_pred),
                    'True_Tg': [test_tg] * len(test_pred) if test_tg is not None else [None] * len(test_pred),
                    'Predicted_Tg': test_pred
                })
                if test_tg is not None:
                    test_df['Absolute_Error'] = np.abs(
                        test_df['True_Tg'] - test_df['Predicted_Tg']
                    )
                    test_df['Relative_Error(%)'] = (
                        test_df['Absolute_Error'] / test_df['True_Tg']
                    ).replace([np.inf, -np.inf], np.nan) * 100
                test_df.to_excel(writer, sheet_name='Test', index=False)

            print(f"所有预测结果已导出到 {filename}")
            return train_df, val_df, test_df
        except Exception as e:
            print(f"导出预测结果时出错: {str(e)}")
            return None, None, None

